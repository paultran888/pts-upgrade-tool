# Anthropic Claude API (get from https://console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-...

# Server
PORT=3090
BASE_URL=http://localhost:3090

# Persistent storage (Railway volume mount path, e.g. /data)
# DATA_DIR=/data

# Stripe (get from https://dashboard.stripe.com/apikeys)
# Create a Product + Price in Stripe Dashboard, then paste the price ID here.
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID=price_...

# Resend (get from https://resend.com/api-keys)
RESEND_API_KEY=re_...
RESEND_FROM=Paul Tran Studio <hello@paultranstudio.com>
PAUL_EMAIL=paul@paultranstudio.com

# Rate limiting (optional — defaults shown)
# RATE_LIMIT_PER_IP=3
# RATE_LIMIT_CONCURRENT=1
# GLOBAL_DAILY_CAP=50
# URL_COOLDOWN_HOURS=24
